# ===== SYMBIO Root Environment Example =====
# Copy this file to .env (root) or to apps/* as needed.

# --- API ---
DATABASE_URL=postgresql+asyncpg://symbio:symbio@127.0.0.1:5435/symbio
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
JWT_EXPIRES_MINUTES=120

# CORS & URLs
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://127.0.0.1:8000

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@symbio.local
EMAIL_DEV_LOG=true

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Steam Web API key (OpenID + GetPlayerSummaries + GetOwnedGames)
STEAM_API_KEY=

# --- Payments (RUB) ---
PAYMENT_PROVIDER=mock
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
DEFAULT_COMMISSION_PERCENT=15

# --- Cron (Vercel: set CRON_SECRET, Authorization: Bearer <secret>) ---
CRON_SECRET=

# --- Search (Meilisearch) ---
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=masterKey

# --- S3/MinIO Storage ---
S3_ENDPOINT=http://localhost:9010
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=symbio

# --- Web ---
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
